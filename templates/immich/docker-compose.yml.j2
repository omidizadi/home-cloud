# Immich docker-compose stack.
# Rendered by homecloud/steps/immich.py from templates/immich/docker-compose.yml.j2.
# Compose files live on the SD card (/opt/homecloud/immich/); data lives on the
# external SSD ({{ immich_datadir }}).

name: immich

services:
  immich-server:
    container_name: immich-server
    image: ghcr.io/immich-app/immich-server:${IMMICH_VERSION:-release}
    # Tailscale Serve terminates TLS on :443 and forwards to this port.
    ports:
      - "{{ immich_web_port }}:2283"
    volumes:
      - {{ upload_location }}:/usr/src/app/upload
      - {{ immich_datadir }}/library:/usr/src/app/external
      - /etc/localtime:/etc/localtime:ro
    env_file: .env
    depends_on:
      redis:
        condition: service_started
      database:
        condition: service_healthy
    restart: always

  immich-machine-learning:
    container_name: immich-machine-learning
    image: ghcr.io/immich-app/immich-machine-learning:${IMMICH_VERSION:-release}
    volumes:
      - {{ immich_datadir }}/model-cache:/cache
      - /etc/localtime:/etc/localtime:ro
    env_file: .env
    restart: always

  redis:
    container_name: immich-redis
    image: docker.io/redis:6.2-alpine@sha256:d6c29137ac999ac3375dc4ed325ae6080b6436f3b09e39c6c6663c1d8f8e5ff
    healthcheck:
      test: redis-cli ping || exit 1
    restart: always

  database:
    container_name: immich-postgres
    image: docker.io/tensorchord/pgvecto-rs:pg14-v0.2.0
    environment:
      POSTGRES_PASSWORD: {{ db_password }}
      POSTGRES_USER: postgres
      POSTGRES_DB: immich
      POSTGRES_INITDB_ARGS: '--data-checksums'
    volumes:
      - {{ immich_datadir }}/pgdata:/var/lib/postgresql/data
      - /etc/localtime:/etc/localtime:ro
    healthcheck:
      test: pg_isready --dbname='immich' --username='postgres' || exit 1
      interval: 5m
      start_period: 5m
    restart: always
