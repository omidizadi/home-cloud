# Immich .env — rendered by homecloud/steps/immich.py.
# This file is mode 0600 (root-owned) because it contains secrets.

DB_HOSTNAME=immich-postgres
DB_USERNAME=postgres
DB_PASSWORD={{ db_password }}
DB_DATABASE_NAME=immich
DB_VECTOR_EXTENSION=pgvector

REDIS_HOSTNAME=immich-redis

JWT_SECRET={{ jwt_secret }}

UPLOAD_LOCATION={{ upload_location }}

# Compose files live on the SD card; data on the SSD.
EXTERNAL={{ immich_datadir }}/library

TZ={{ timezone }}

# Pin to the latest release tag. Override by setting IMMICH_VERSION in the
# environment before running the install step.
IMMICH_VERSION=release
